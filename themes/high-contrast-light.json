{
  "schemaVersion": 1,
  "name": "High Contrast Light",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": true,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "flat",
      "highContrast",
      "light"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "alphaKey": "#FFFFFF",
    "modifierKey": "#EFEFEF",
    "accentKey": "#E0E0E0",
    "keyPressed": "#C8D7EA",
    "keyboardBackground": "#F3F4F6",
    "border": "#111111",
    "depth": null,
    "accent": "#000000",
    "secondary": "#424242"
  },
  "shape": {
    "roundnessDp": 5,
    "keyGapDp": 6,
    "depthEnabled": false,
    "depthDp": 0,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#000000",
      "background": "#FFFFFF"
    },
    "mod": {
      "foreground": "#424242",
      "background": "#EFEFEF"
    },
    "modInv": {
      "foreground": "#EFEFEF",
      "background": "#E0E0E0"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#06B6D4"
  }
}
