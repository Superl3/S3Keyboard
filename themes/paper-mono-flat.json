{
  "schemaVersion": 1,
  "name": "Paper Mono Flat",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": false,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "flat",
      "light",
      "minimal"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "alphaKey": "#FAFAFA",
    "modifierKey": "#EFEFEF",
    "accentKey": "#E5E5E5",
    "keyPressed": "#DADADA",
    "keyboardBackground": "#F4F4F4",
    "border": "#D0D0D0",
    "depth": null,
    "accent": "#111111",
    "secondary": "#777777"
  },
  "shape": {
    "roundnessDp": 3,
    "keyGapDp": 6,
    "depthEnabled": false,
    "depthDp": 0,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "d2coding",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#111111",
      "background": "#FAFAFA"
    },
    "mod": {
      "foreground": "#777777",
      "background": "#EFEFEF"
    },
    "modInv": {
      "foreground": "#EFEFEF",
      "background": "#E5E5E5"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#16A34A"
  }
}
