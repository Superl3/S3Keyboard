{
  "schemaVersion": 1,
  "name": "GMK Bento Inspired",
  "author": "local",
  "metadata": {
    "tags": [
      "dark",
      "depth",
      "gmkInspired"
    ],
    "features": [
      "dingulRoleColors"
    ]
  },
  "colors": {
    "alphaKey": "#E8E0D3",
    "modifierKey": "#2E6687",
    "accentKey": "#E66D61",
    "keyPressed": "#CBBFAE",
    "keyboardBackground": "#9DA7A4",
    "border": "#5C6E72",
    "depth": "#5C6E72",
    "accent": "#234E68",
    "secondary": "#FFF3E7"
  },
  "shape": {
    "roundnessDp": 5,
    "borderWidthDp": 1,
    "keyGapDp": 5,
    "depthEnabled": true,
    "depthDp": 2
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#2F8CA1"
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#234E68",
      "background": "#E8E0D3"
    },
    "mod": {
      "foreground": "#FFF3E7",
      "background": "#2E6687"
    },
    "modInv": {
      "foreground": "#FFF3E7",
      "background": "#E66D61"
    }
  },
  "accentPolicy": {
    "qwerty": [
      "modMeta",
      "qwertyShift",
      "backspace"
    ],
    "dingul": [
      "modCtrl",
      "dingulDot"
    ]
  }
}
