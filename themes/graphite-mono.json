{
  "schemaVersion": 1,
  "name": "Graphite Mono",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": false,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "depth",
      "light",
      "minimal"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "keyIdle": "#F5F5F5",
    "functionKey": "#E8E8E8",
    "primaryFunctionKey": "#DDDDDD",
    "accentKey": "#DDDDDD",
    "keyPressed": "#CFCFCF",
    "keyboardBackground": "#EDEDED",
    "border": "#B8B8B8",
    "depth": "#B8B8B8",
    "accent": "#161616",
    "secondary": "#686868"
  },
  "shape": {
    "roundnessDp": 4,
    "keyGapDp": 6,
    "depthEnabled": true,
    "depthDp": 1,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "d2coding",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": false,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#161616",
      "background": "#F5F5F5"
    },
    "mod": {
      "foreground": "#686868",
      "background": "#E8E8E8"
    },
    "modInv": {
      "foreground": "#E8E8E8",
      "background": "#DDDDDD"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#16A34A"
  }
}
