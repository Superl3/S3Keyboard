{
  "schemaVersion": 1,
  "name": "macOS Graphite Dark",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": true,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "dark",
      "depth",
      "minimal",
      "platformInspired"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "alphaKey": "#30343A",
    "modifierKey": "#3B414A",
    "accentKey": "#252B32",
    "keyPressed": "#596271",
    "keyboardBackground": "#20242A",
    "border": "#15191F",
    "depth": "#15191F",
    "accent": "#F4F7FA",
    "secondary": "#AEB7C4"
  },
  "shape": {
    "roundnessDp": 6,
    "keyGapDp": 5,
    "depthEnabled": true,
    "depthDp": 2,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#F4F7FA",
      "background": "#30343A"
    },
    "mod": {
      "foreground": "#AEB7C4",
      "background": "#3B414A"
    },
    "modInv": {
      "foreground": "#3B414A",
      "background": "#252B32"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#16A34A"
  }
}
