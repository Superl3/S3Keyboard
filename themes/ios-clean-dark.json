{
  "schemaVersion": 1,
  "name": "iOS Clean Dark",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": false,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "dark",
      "flat",
      "minimal",
      "platformInspired"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "keyIdle": "#2B2D31",
    "functionKey": "#3A3D43",
    "primaryFunctionKey": "#202328",
    "accentKey": "#202328",
    "keyPressed": "#5A5E66",
    "keyboardBackground": "#1D1F23",
    "border": "#202328",
    "depth": null,
    "accent": "#F8FAFC",
    "secondary": "#B8BEC8"
  },
  "shape": {
    "roundnessDp": 8,
    "keyGapDp": 5,
    "depthEnabled": false,
    "depthDp": 0,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": false,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#F8FAFC",
      "background": "#2B2D31"
    },
    "mod": {
      "foreground": "#B8BEC8",
      "background": "#3A3D43"
    },
    "modInv": {
      "foreground": "#3A3D43",
      "background": "#202328"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#06B6D4"
  }
}
