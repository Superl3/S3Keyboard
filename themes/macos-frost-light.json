{
  "schemaVersion": 1,
  "name": "macOS Frost Light",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": true,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "depth",
      "light",
      "platformInspired"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "alphaKey": "#F6F7F9",
    "modifierKey": "#E7EAEE",
    "accentKey": "#DCE2EA",
    "keyPressed": "#C9D2DC",
    "keyboardBackground": "#EEF1F4",
    "border": "#B8C0CA",
    "depth": "#B8C0CA",
    "accent": "#1F2937",
    "secondary": "#667085"
  },
  "shape": {
    "roundnessDp": 6,
    "keyGapDp": 5,
    "depthEnabled": true,
    "depthDp": 2,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#1F2937",
      "background": "#F6F7F9"
    },
    "mod": {
      "foreground": "#667085",
      "background": "#E7EAEE"
    },
    "modInv": {
      "foreground": "#E7EAEE",
      "background": "#DCE2EA"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#0891B2"
  }
}
