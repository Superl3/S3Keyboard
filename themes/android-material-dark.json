{
  "schemaVersion": 1,
  "name": "Android Material Dark",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": true,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "dark",
      "flat",
      "platformInspired"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "keyIdle": "#211F26",
    "functionKey": "#2B2930",
    "primaryFunctionKey": "#17151B",
    "accentKey": "#17151B",
    "keyPressed": "#4A4458",
    "keyboardBackground": "#141218",
    "border": "#49454F",
    "depth": null,
    "accent": "#E6E1E5",
    "secondary": "#CAC4D0"
  },
  "shape": {
    "roundnessDp": 12,
    "keyGapDp": 5,
    "depthEnabled": false,
    "depthDp": 0,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": false,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#E6E1E5",
      "background": "#211F26"
    },
    "mod": {
      "foreground": "#CAC4D0",
      "background": "#2B2930"
    },
    "modInv": {
      "foreground": "#2B2930",
      "background": "#17151B"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#16A34A"
  }
}
