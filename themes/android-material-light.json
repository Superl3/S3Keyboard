{
  "schemaVersion": 1,
  "name": "Android Material Light",
  "author": "local",
  "metadata": {
    "recommendedHints": {
      "showHangulSlideHints": true,
      "showEnglishSlideHints": false,
      "showBeginnerTooltipPreview": true
    },
    "tags": [
      "flat",
      "light",
      "platformInspired"
    ],
    "features": [
      "dingulRoleColors",
      "historicalHintRecommendation"
    ]
  },
  "colors": {
    "alphaKey": "#FFFBFE",
    "modifierKey": "#ECE6F0",
    "accentKey": "#E1DCE8",
    "keyPressed": "#D0C4DB",
    "keyboardBackground": "#F3EDF7",
    "border": "#CAC4D0",
    "depth": null,
    "accent": "#1D1B20",
    "secondary": "#625B71"
  },
  "shape": {
    "roundnessDp": 12,
    "keyGapDp": 5,
    "depthEnabled": false,
    "depthDp": 0,
    "borderWidthDp": 1
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#1D1B20",
      "background": "#FFFBFE"
    },
    "mod": {
      "foreground": "#625B71",
      "background": "#ECE6F0"
    },
    "modInv": {
      "foreground": "#ECE6F0",
      "background": "#E1DCE8"
    }
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#16A34A"
  }
}
