{
  "schemaVersion": 1,
  "name": "GMK Modern Dolch Inspired",
  "author": "local",
  "metadata": {
    "tags": [
      "dark",
      "depth",
      "gmkInspired"
    ],
    "features": [
      "dingulRoleColors"
    ]
  },
  "colors": {
    "alphaKey": "#616A70",
    "modifierKey": "#2A2F34",
    "accentKey": "#2E6F70",
    "keyPressed": "#4A5258",
    "keyboardBackground": "#555B60",
    "border": "#202327",
    "depth": "#202327",
    "accent": "#E8ECEF",
    "secondary": "#64D4CF"
  },
  "shape": {
    "roundnessDp": 5,
    "borderWidthDp": 1,
    "keyGapDp": 5,
    "depthEnabled": true,
    "depthDp": 2
  },
  "additionalNumberRow": {
    "colorMode": "full_mod"
  },
  "typography": {
    "fontFamily": "noto_sans_kr",
    "primaryTextSizePercent": 78,
    "secondaryTextSizePercent": 80,
    "primaryTextBold": false,
    "primaryTextItalic": false,
    "secondaryTextBold": true,
    "secondaryTextItalic": false
  },
  "keyTextColorOverrides": {
    "shiftIndicator": "#55C7C8"
  },
  "dingulColors": {
    "alpha": {
      "foreground": "#E8ECEF",
      "background": "#616A70"
    },
    "mod": {
      "foreground": "#64D4CF",
      "background": "#2A2F34"
    },
    "modInv": {
      "foreground": "#2A2F34",
      "background": "#2E6F70"
    }
  },
  "accentPolicy": {
    "qwerty": [
      "modMeta",
      "qwertyShift",
      "backspace"
    ],
    "dingul": [
      "modCtrl",
      "dingulDot"
    ]
  }
}
